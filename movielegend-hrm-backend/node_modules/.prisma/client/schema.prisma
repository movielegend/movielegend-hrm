model OvertimeRateRule {
  id            String       @id @default(uuid()) @db.Uuid
  companyId     String       @db.Uuid
  overtimeType  OvertimeType
  multiplier    Decimal      @db.Decimal(6, 3)
  effectiveFrom DateTime     @db.Date
  effectiveTo   DateTime?    @db.Date
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  company       Company      @relation(fields: [companyId], references: [id])

  @@index([companyId, overtimeType, effectiveFrom, effectiveTo])
  @@map("overtime_rate_rules")
}

model ContractTemplate {
  id              String                    @id @default(uuid()) @db.Uuid
  companyId       String                    @db.Uuid
  code            String
  name            String
  contractType    ContractType
  description     String?
  templateFileUrl String
  storageKey      String?
  version         Int                       @default(1)
  isActive        Boolean                   @default(true)
  createdById     String                    @db.Uuid
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  deletedAt       DateTime?
  company         Company                   @relation(fields: [companyId], references: [id])
  createdBy       User                      @relation("ContractTemplateCreator", fields: [createdById], references: [id])
  versions        ContractTemplateVersion[]
  contracts       EmployeeContract[]

  @@unique([companyId, code])
  @@index([companyId, contractType, isActive])
  @@map("contract_templates")
}

model ContractTemplateVersion {
  id                 String             @id @default(uuid()) @db.Uuid
  contractTemplateId String             @db.Uuid
  versionNumber      Int
  templateFileUrl    String
  storageKey         String?
  contentHash        String?
  createdById        String             @db.Uuid
  createdAt          DateTime           @default(now())
  contractTemplate   ContractTemplate   @relation(fields: [contractTemplateId], references: [id])
  createdBy          User               @relation("ContractTemplateVersionCreator", fields: [createdById], references: [id])
  contracts          EmployeeContract[]

  @@unique([contractTemplateId, versionNumber])
  @@map("contract_template_versions")
}

model EmployeeContract {
  id                            String                  @id @default(uuid()) @db.Uuid
  contractCode                  String                  @unique
  userId                        String                  @db.Uuid
  contractTemplateId            String                  @db.Uuid
  contractTemplateVersionId     String                  @db.Uuid
  contractType                  ContractType
  title                         String
  startDate                     DateTime                @db.Date
  endDate                       DateTime?               @db.Date
  status                        ContractStatus          @default(DRAFT)
  baseSalarySnapshot            Json?
  positionSnapshot              Json?
  departmentSnapshot            Json?
  draftFileUrl                  String?
  signedFileUrl                 String?
  createdById                   String                  @db.Uuid
  approvedById                  String?                 @db.Uuid
  approvedAt                    DateTime?
  employeeSignedAt              DateTime?
  companySignedAt               DateTime?
  effectiveAt                   DateTime?
  terminatedAt                  DateTime?
  terminationReason             String?
  employeeAcknowledgementStatus AcknowledgementStatus   @default(PENDING)
  employeeAcknowledgedAt        DateTime?
  employeeAcknowledgementNote   String?
  employeeAcknowledgedByIp      String?
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  user                          User                    @relation("EmployeeContractUser", fields: [userId], references: [id])
  contractTemplate              ContractTemplate        @relation(fields: [contractTemplateId], references: [id])
  contractTemplateVersion       ContractTemplateVersion @relation(fields: [contractTemplateVersionId], references: [id])
  createdBy                     User                    @relation("EmployeeContractCreator", fields: [createdById], references: [id])
  approvedBy                    User?                   @relation("EmployeeContractApprover", fields: [approvedById], references: [id])
  signatures                    ContractSignature[]

  @@index([userId, status])
  @@index([status, endDate])
  @@index([contractTemplateId])
  @@map("employee_contracts")
}

model ContractSignature {
  id                 String             @id @default(uuid()) @db.Uuid
  contractId         String             @db.Uuid
  signerUserId       String             @db.Uuid
  signerRole         ContractSignerRole
  signatureType      SignatureType
  signatureImageUrl  String?
  signatureDataHash  String?
  signedDocumentHash String?
  ipAddress          String?
  deviceInfo         String?
  signedAt           DateTime           @default(now())
  createdAt          DateTime           @default(now())
  contract           EmployeeContract   @relation(fields: [contractId], references: [id])
  signer             User               @relation("ContractSignatureSigner", fields: [signerUserId], references: [id])

  @@unique([contractId, signerUserId, signerRole])
  @@index([contractId, signerRole])
  @@map("contract_signatures")
}

model KpiTemplate {
  id           String                  @id @default(uuid()) @db.Uuid
  companyId    String                  @db.Uuid
  departmentId String?                 @db.Uuid
  positionId   String?                 @db.Uuid
  code         String
  name         String
  description  String?
  periodType   KpiPeriodType
  isActive     Boolean                 @default(true)
  createdById  String                  @db.Uuid
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  deletedAt    DateTime?
  company      Company                 @relation(fields: [companyId], references: [id])
  department   Department?             @relation(fields: [departmentId], references: [id])
  position     Position?               @relation(fields: [positionId], references: [id])
  createdBy    User                    @relation("KpiTemplateCreator", fields: [createdById], references: [id])
  criteria     KpiCriteria[]
  assignments  EmployeeKpiAssignment[]

  @@unique([companyId, code])
  @@index([departmentId, positionId, isActive])
  @@map("kpi_templates")
}

model KpiCriteria {
  id            String              @id @default(uuid()) @db.Uuid
  kpiTemplateId String              @db.Uuid
  code          String
  name          String
  description   String?
  weight        Decimal             @db.Decimal(6, 2)
  targetValue   String?
  unit          String?
  scoringMethod KpiScoringMethod    @default(MANUAL)
  sortOrder     Int                 @default(0)
  isRequired    Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  kpiTemplate   KpiTemplate         @relation(fields: [kpiTemplateId], references: [id], onDelete: Cascade)
  results       EmployeeKpiResult[]

  @@unique([kpiTemplateId, code])
  @@index([kpiTemplateId, sortOrder])
  @@map("kpi_criteria")
}

model EmployeeKpiAssignment {
  id            String                      @id @default(uuid()) @db.Uuid
  userId        String                      @db.Uuid
  kpiTemplateId String                      @db.Uuid
  periodStart   DateTime                    @db.Date
  periodEnd     DateTime                    @db.Date
  status        EmployeeKpiAssignmentStatus @default(DRAFT)
  assignedById  String                      @db.Uuid
  assignedAt    DateTime                    @default(now())
  submittedAt   DateTime?
  reviewedAt    DateTime?
  finalizedAt   DateTime?
  finalScore    Decimal?                    @db.Decimal(6, 2)
  snapshot      Json?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  user          User                        @relation("KpiAssignmentUser", fields: [userId], references: [id])
  kpiTemplate   KpiTemplate                 @relation(fields: [kpiTemplateId], references: [id])
  assignedBy    User                        @relation("KpiAssignmentAssigner", fields: [assignedById], references: [id])
  results       EmployeeKpiResult[]

  @@unique([userId, kpiTemplateId, periodStart, periodEnd])
  @@index([userId, status, periodStart, periodEnd])
  @@index([status, periodEnd])
  @@map("employee_kpi_assignments")
}

model EmployeeKpiResult {
  id                      String                @id @default(uuid()) @db.Uuid
  employeeKpiAssignmentId String                @db.Uuid
  criteriaId              String                @db.Uuid
  targetValue             String?
  actualValue             String?
  employeeScore           Decimal?              @db.Decimal(6, 2)
  leaderScore             Decimal?              @db.Decimal(6, 2)
  finalScore              Decimal?              @db.Decimal(6, 2)
  employeeComment         String?
  leaderComment           String?
  finalComment            String?
  evidenceUrl             String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  assignment              EmployeeKpiAssignment @relation(fields: [employeeKpiAssignmentId], references: [id], onDelete: Cascade)
  criteria                KpiCriteria           @relation(fields: [criteriaId], references: [id])

  @@unique([employeeKpiAssignmentId, criteriaId])
  @@map("employee_kpi_results")
}

model PerformanceReviewCycle {
  id                  String                       @id @default(uuid()) @db.Uuid
  companyId           String                       @db.Uuid
  code                String
  name                String
  periodStart         DateTime                     @db.Date
  periodEnd           DateTime                     @db.Date
  selfReviewStart     DateTime                     @db.Date
  selfReviewEnd       DateTime                     @db.Date
  leaderReviewStart   DateTime                     @db.Date
  leaderReviewEnd     DateTime                     @db.Date
  finalReviewStart    DateTime                     @db.Date
  finalReviewEnd      DateTime                     @db.Date
  status              PerformanceReviewCycleStatus @default(DRAFT)
  createdById         String                       @db.Uuid
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt
  company             Company                      @relation(fields: [companyId], references: [id])
  createdBy           User                         @relation("ReviewCycleCreator", fields: [createdById], references: [id])
  reviews             PerformanceReview[]
  reviewerAssignments ReviewerAssignment[]

  @@unique([companyId, code])
  @@index([status, periodStart, periodEnd])
  @@map("performance_review_cycles")
}

model PerformanceReview {
  id             String                  @id @default(uuid()) @db.Uuid
  cycleId        String                  @db.Uuid
  userId         String                  @db.Uuid
  reviewerUserId String?                 @db.Uuid
  status         PerformanceReviewStatus @default(PENDING)
  selfSummary    String?
  leaderSummary  String?
  finalSummary   String?
  selfScore      Decimal?                @db.Decimal(6, 2)
  leaderScore    Decimal?                @db.Decimal(6, 2)
  finalScore     Decimal?                @db.Decimal(6, 2)
  submittedAt    DateTime?
  reviewedAt     DateTime?
  finalizedAt    DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  cycle          PerformanceReviewCycle  @relation(fields: [cycleId], references: [id])
  user           User                    @relation("PerformanceReviewUser", fields: [userId], references: [id])
  reviewer       User?                   @relation("PerformanceReviewReviewer", fields: [reviewerUserId], references: [id])

  @@unique([cycleId, userId])
  @@index([reviewerUserId, status])
  @@index([userId, status])
  @@map("performance_reviews")
}

model ReviewerAssignment {
  id             String                 @id @default(uuid()) @db.Uuid
  reviewCycleId  String                 @db.Uuid
  employeeUserId String                 @db.Uuid
  reviewerUserId String                 @db.Uuid
  reviewerType   ReviewerType
  createdAt      DateTime               @default(now())
  reviewCycle    PerformanceReviewCycle @relation(fields: [reviewCycleId], references: [id])
  employee       User                   @relation("ReviewerAssignmentEmployee", fields: [employeeUserId], references: [id])
  reviewer       User                   @relation("ReviewerAssignmentReviewer", fields: [reviewerUserId], references: [id])

  @@unique([reviewCycleId, employeeUserId, reviewerUserId, reviewerType])
  @@index([reviewerUserId, reviewerType])
  @@map("reviewer_assignments")
}

model SystemSetting {
