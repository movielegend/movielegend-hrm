  approvedById  String?                  @db.Uuid
  approvedAt    DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  violation     Violation                @relation(fields: [violationId], references: [id])
  approvedBy    User?                    @relation("DisciplinaryActionApprover", fields: [approvedById], references: [id])

  @@index([violationId, status])
  @@map("disciplinary_actions")
