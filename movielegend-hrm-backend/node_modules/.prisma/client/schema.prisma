model User {
  id                              String                       @id @default(uuid()) @db.Uuid
  userCode                        String                       @unique
  phone                           String                       @unique
  email                           String?                      @unique
  passwordHash                    String
  accountStatus                   AccountStatus                @default(PENDING)
  approvalStatus                  ApprovalStatus               @default(PENDING)
  isActive                        Boolean                      @default(false)
  lastLoginAt                     DateTime?
  createdAt                       DateTime                     @default(now())
  updatedAt                       DateTime                     @updatedAt
  deletedAt                       DateTime?
  profile                         EmployeeProfile?
  roles                           UserRole[]
  refreshSessions                 RefreshSession[]
  approvalRequests                UserApprovalRequest[]
  approvalActions                 ApprovalHistory[]            @relation("ApprovalActor")
  auditLogs                       AuditLog[]                   @relation("AuditActor")
  ledDepartments                  Department[]                 @relation("DepartmentLeader")
  departmentLinks                 DepartmentMember[]
  faceProfile                     FaceProfile?
  shiftAssignments                ShiftAssignment[]
  shiftRegistrations              ShiftRegistration[]
  requestedShiftSwaps             ShiftSwap[]                  @relation("ShiftSwapRequester")
  targetShiftSwaps                ShiftSwap[]                  @relation("ShiftSwapTarget")
  attendanceRecords               AttendanceRecord[]
  attendanceAdjustments           AttendanceAdjustment[]
  locationTrackings               LocationTracking[]
  leaveBalances                   LeaveBalance[]
  leaveRequests                   LeaveRequest[]
  overtimeRequests                OvertimeRequest[]
  employeeRequests                EmployeeRequest[]
  createdTasks                    Task[]                       @relation("TaskCreator")
  groupLeaderTasks                Task[]                       @relation("TaskGroupLeader")
  taskAssignments                 TaskAssignment[]             @relation("TaskAssignee")
  assignedTasks                   TaskAssignment[]             @relation("TaskAssigner")
  reviewedTasks                   TaskAssignment[]             @relation("TaskReviewer")
  taskComments                    TaskComment[]
  taskAttachments                 TaskAttachment[]
  taskHistories                   TaskStatusHistory[]
  taskExtensionRequests           TaskExtensionRequest[]       @relation("TaskExtensionRequester")
  decidedTaskExtensions           TaskExtensionRequest[]       @relation("TaskExtensionDecider")
  taskGroupMemberships            TaskGroupMember[]
  createdTaskGroups               TaskGroup[]                  @relation("TaskGroupCreator")
  crossRequestsCreated            CrossDepartmentRequest[]     @relation("CrossRequestCreator")
  crossRequestsDecided            CrossDepartmentRequest[]     @relation("CrossRequestDecider")
  notifications                   NotificationTarget[]
  notificationDeliveries          NotificationDelivery[]
  deviceTokens                    DeviceToken[]
  managedWarehouses               Warehouse[]                  @relation("WarehouseManager")
  stockTransactions               StockTransaction[]           @relation("StockTransactionPerformer")
  createdStockReceipts            StockReceipt[]               @relation("StockReceiptCreator")
  approvedStockReceipts           StockReceipt[]               @relation("StockReceiptApprover")
  materialIssueTargets            MaterialIssue[]              @relation("MaterialIssueUserTarget")
  requestedMaterialIssues         MaterialIssue[]              @relation("MaterialIssueRequester")
  approvedMaterialIssues          MaterialIssue[]              @relation("MaterialIssueApprover")
  issuedMaterialIssues            MaterialIssue[]              @relation("MaterialIssueIssuer")
  materialReturns                 MaterialReturn[]             @relation("MaterialReturnUser")
  receivedMaterialReturns         MaterialReturn[]             @relation("MaterialReturnReceiver")
  requestedStockTransfers         StockTransfer[]              @relation("StockTransferRequester")
  approvedStockTransfers          StockTransfer[]              @relation("StockTransferApprover")
  shippedStockTransfers           StockTransfer[]              @relation("StockTransferShipper")
  receivedStockTransfers          StockTransfer[]              @relation("StockTransferReceiver")
  assetAssignments                AssetAssignment[]            @relation("AssetAssignmentUserTarget")
  assignedAssets                  AssetAssignment[]            @relation("AssetAssignmentAssigner")
  assetAssignmentHistories        AssetAssignmentHistory[]     @relation("AssetAssignmentHistoryActor")
  assetIncidentReports            AssetIncidentReport[]        @relation("AssetIncidentReporter")
  resolvedAssetIncidents          AssetIncidentReport[]        @relation("AssetIncidentResolver")
  assetMaintenanceRecords         AssetMaintenanceRecord[]     @relation("AssetMaintenanceCreator")
  createdInventoryChecks          InventoryCheck[]             @relation("InventoryCheckCreator")
  approvedInventoryChecks         InventoryCheck[]             @relation("InventoryCheckApprover")
  salaryProfiles                  SalaryProfile[]              @relation("SalaryProfileUser")
  createdSalaryProfiles           SalaryProfile[]              @relation("SalaryProfileCreator")
  employeeSalaryComponents        EmployeeSalaryComponent[]    @relation("EmployeeSalaryComponentUser")
  createdEmployeeSalaryComponents EmployeeSalaryComponent[]    @relation("EmployeeSalaryComponentCreator")
  payrollPeriodsCreated           PayrollPeriod[]              @relation("PayrollPeriodCreator")
  payrollPeriodsReviewed          PayrollPeriod[]              @relation("PayrollPeriodReviewer")
  payrollPeriodsApproved          PayrollPeriod[]              @relation("PayrollPeriodApprover")
  payrollPeriodsLocked            PayrollPeriod[]              @relation("PayrollPeriodLocker")
  payrolls                        Payroll[]
  employeeBonuses                 EmployeeBonus[]              @relation("EmployeeBonusUser")
  createdEmployeeBonuses          EmployeeBonus[]              @relation("EmployeeBonusCreator")
  approvedEmployeeBonuses         EmployeeBonus[]              @relation("EmployeeBonusApprover")
  employeeDeductions              EmployeeDeduction[]          @relation("EmployeeDeductionUser")
  createdEmployeeDeductions       EmployeeDeduction[]          @relation("EmployeeDeductionCreator")
  approvedEmployeeDeductions      EmployeeDeduction[]          @relation("EmployeeDeductionApprover")
  violations                      Violation[]                  @relation("ViolationUser")
  createdViolations               Violation[]                  @relation("ViolationCreator")
  confirmedViolations             Violation[]                  @relation("ViolationConfirmer")
  approvedDisciplinaryActions     DisciplinaryAction[]         @relation("DisciplinaryActionApprover")
  employeeDocuments               EmployeeDocument[]           @relation("EmployeeDocumentUser")
  verifiedEmployeeDocuments       EmployeeDocument[]           @relation("EmployeeDocumentVerifier")
  createdContractTemplates        ContractTemplate[]           @relation("ContractTemplateCreator")
  createdContractTemplateVersions ContractTemplateVersion[]    @relation("ContractTemplateVersionCreator")
  employeeContracts               EmployeeContract[]           @relation("EmployeeContractUser")
  createdEmployeeContracts        EmployeeContract[]           @relation("EmployeeContractCreator")
  approvedEmployeeContracts       EmployeeContract[]           @relation("EmployeeContractApprover")
  contractSignatures              ContractSignature[]          @relation("ContractSignatureSigner")
  createdKpiTemplates             KpiTemplate[]                @relation("KpiTemplateCreator")
  kpiAssignments                  EmployeeKpiAssignment[]      @relation("KpiAssignmentUser")
  assignedKpiAssignments          EmployeeKpiAssignment[]      @relation("KpiAssignmentAssigner")
  createdReviewCycles             PerformanceReviewCycle[]     @relation("ReviewCycleCreator")
  performanceReviews              PerformanceReview[]          @relation("PerformanceReviewUser")
  reviewedPerformanceReviews      PerformanceReview[]          @relation("PerformanceReviewReviewer")
  reviewerAssignmentsForEmployee  ReviewerAssignment[]         @relation("ReviewerAssignmentEmployee")
  reviewerAssignmentsAsReviewer   ReviewerAssignment[]         @relation("ReviewerAssignmentReviewer")
  updatedSystemSettings           SystemSetting[]              @relation("SystemSettingUpdater")
  notificationPreferences         UserNotificationPreference[]
  reportSnapshots                 ReportSnapshot[]             @relation("ReportSnapshotGenerator")
  uploadedFiles                   UploadedFile[]               @relation("UploadedFileUploader")
  posts                           NewsfeedPost[]
  postComments                    PostComment[]
  postLikes                       PostLike[]
  chatMessages                    ChatMessage[]
  chatGroupMembers                ChatGroupMember[]

  @@map("users")
}

model UploadedFile {
  id                String             @id @default(uuid()) @db.Uuid
  uploadedById      String?            @db.Uuid
  purpose           UploadPurpose
  fileName          String
  storageKey        String             @unique
  fileUrl           String
  mimeType          String
  size              Int
  checksum          String?
  status            UploadedFileStatus @default(TEMPORARY)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  uploadedBy        User?              @relation("UploadedFileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  attendanceRecords AttendanceRecord[] @relation("AttendancePhotoFile")

  @@index([purpose, status, createdAt])
  @@index([uploadedById])
  @@map("uploaded_files")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  userRoles   UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @db.Uuid
  roleId    String        @db.Uuid
  scopeType RoleScopeType @default(GLOBAL)
  scopeId   String?       @db.Uuid
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, scopeType, scopeId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Company {
  id                String                   @id @default(uuid()) @db.Uuid
  code              String                   @unique
  name              String
  description       String?
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  branches          Branch[]
  departments       Department[]
  warehouses        Warehouse[]
  payrollPeriods    PayrollPeriod[]
  overtimeRateRules OvertimeRateRule[]
  documentTypes     DocumentType[]
  contractTemplates ContractTemplate[]
  kpiTemplates      KpiTemplate[]
  reviewCycles      PerformanceReviewCycle[]
  systemSettings    SystemSetting[]

  @@map("companies")
}

model Branch {
  id                  String               @id @default(uuid()) @db.Uuid
  companyId           String               @db.Uuid
  code                String
  name                String
  address             String?
  latitude            Decimal?             @db.Decimal(10, 7)
  longitude           Decimal?             @db.Decimal(10, 7)
  allowedRadius       Int?                 @default(100)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  company             Company              @relation(fields: [companyId], references: [id])
  departments         Department[]
  warehouses          Warehouse[]
  attendanceLocations AttendanceLocation[]

  @@unique([companyId, code])
  @@map("branches")
}

model Department {
  id                    String                   @id @default(uuid()) @db.Uuid
  companyId             String                   @db.Uuid
  branchId              String?                  @db.Uuid
  parentId              String?                  @db.Uuid
  code                  String
  name                  String
  description           String?
  leaderUserId          String?                  @db.Uuid
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  company               Company                  @relation(fields: [companyId], references: [id])
  branch                Branch?                  @relation(fields: [branchId], references: [id])
  parent                Department?              @relation("DepartmentTree", fields: [parentId], references: [id])
  children              Department[]             @relation("DepartmentTree")
  leader                User?                    @relation("DepartmentLeader", fields: [leaderUserId], references: [id])
  members               DepartmentMember[]
  positions             Position[]
  requests              UserApprovalRequest[]
  shiftAssignments      ShiftAssignment[]
  shiftRegistrations    ShiftRegistration[]
  shiftSwaps            ShiftSwap[]
  wifiConfigs           WifiConfig[]
  attendanceLocations   AttendanceLocation[]     @relation("AttendanceLocationDepartments")
  attendanceRecords     AttendanceRecord[]
  attendanceAdjustments AttendanceAdjustment[]
  leaveRequests         LeaveRequest[]
  overtimeRequests      OvertimeRequest[]
  employeeRequests      EmployeeRequest[]
  tasks                 Task[]
  taskGroups            TaskGroup[]
  crossRequestsSource   CrossDepartmentRequest[] @relation("CrossRequestSourceDepartment")
  crossRequestsTarget   CrossDepartmentRequest[] @relation("CrossRequestTargetDepartment")
  warehouses            Warehouse[]
  materialIssueTargets  MaterialIssue[]          @relation("MaterialIssueDepartmentTarget")
  materialReturns       MaterialReturn[]         @relation("MaterialReturnDepartment")
  assetAssignments      AssetAssignment[]        @relation("AssetAssignmentDepartmentTarget")
  kpiTemplates          KpiTemplate[]
  newsfeedPosts         NewsfeedPost[]
  chatGroup             ChatGroup?
  assets                Asset[]

  @@unique([companyId, code])
  @@map("departments")
}

model Position {
  id           String             @id @default(uuid()) @db.Uuid
  departmentId String?            @db.Uuid
  code         String             @unique
  name         String
  description  String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?
  department   Department?        @relation(fields: [departmentId], references: [id])
  profiles     EmployeeProfile[]
  members      DepartmentMember[]
  kpiTemplates KpiTemplate[]

  @@map("positions")
}

model DepartmentMember {
  id           String     @id @default(uuid()) @db.Uuid
  departmentId String     @db.Uuid
  userId       String     @db.Uuid
  positionId   String?    @db.Uuid
  isPrimary    Boolean    @default(true)
  joinedAt     DateTime   @default(now())
  leftAt       DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  position     Position?  @relation(fields: [positionId], references: [id])

  @@unique([departmentId, userId])
  @@map("department_members")
}

model EmployeeProfile {
  id                    String                @id @default(uuid()) @db.Uuid
  userId                String                @unique @db.Uuid
  fullName              String
  dateOfBirth           DateTime?
  gender                Gender?
  idCardNumber          String                @unique
  idCardIssueDate       DateTime?
  idCardIssuePlace      String?
  idCardFrontUrl        String?
  idCardBackUrl         String?
  permanentAddress      String?
  temporaryAddress      String?
  avatarUrl             String?
  joinDate              DateTime?
  officialDate          DateTime?
  employmentStatus      EmploymentStatus      @default(PROBATION)
  emergencyContactName  String?
  emergencyContactPhone String?
