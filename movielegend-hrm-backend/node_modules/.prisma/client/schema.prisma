  relatedEntityId   String?              @db.Uuid
  title             String
  description       String
  violationDate     DateTime             @db.Date
  status            ViolationStatus      @default(PENDING_REVIEW)
  createdById       String               @db.Uuid
  confirmedById     String?              @db.Uuid
  confirmedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  user              User                 @relation("ViolationUser", fields: [userId], references: [id])
  createdBy         User                 @relation("ViolationCreator", fields: [createdById], references: [id])
  confirmedBy       User?                @relation("ViolationConfirmer", fields: [confirmedById], references: [id])
  actions           DisciplinaryAction[]

  @@index([userId, status, violationDate])
  @@map("violations")
}

model DisciplinaryAction {
  id            String                   @id @default(uuid()) @db.Uuid
  violationId   String                   @db.Uuid
  actionType    DisciplinaryActionType
  amount        Decimal?                 @db.Decimal(14, 2)
  description   String
  effectiveDate DateTime                 @db.Date
