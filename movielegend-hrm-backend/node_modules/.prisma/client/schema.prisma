  deductionType     String
  title             String
  description       String?
  amount            Decimal                 @db.Decimal(14, 2)
  effectiveDate     DateTime                @db.Date
  status            EmployeeDeductionStatus @default(PENDING)
  approvedById      String?                 @db.Uuid
  approvedAt        DateTime?
  relatedEntityType String?
  relatedEntityId   String?                 @db.Uuid
  createdById       String                  @db.Uuid
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  user              User                    @relation("EmployeeDeductionUser", fields: [userId], references: [id])
  approvedBy        User?                   @relation("EmployeeDeductionApprover", fields: [approvedById], references: [id])
  createdBy         User                    @relation("EmployeeDeductionCreator", fields: [createdById], references: [id])

  @@index([userId, status, effectiveDate])
  @@map("employee_deductions")
}

model Violation {
