{
  "cli": {
    "version": ">= 20.5.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://glimmer-icky-status.ngrok-free.dev/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://glimmer-icky-status.ngrok-free.dev",
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=-Xmx2048m -Dkotlin.compiler.execution.strategy=in-process"
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
